# ==========================================
# Variáveis de Ambiente Necessárias (Produção)
# ==========================================

# A URL do seu banco de dados Postgres gerenciado (ex: Supabase, Render, Railway)
DATABASE_URL="sua_connection_string_aqui_ex_postgres://user:pass@host:5432/db"

# Segredo criptográfico para geração de tokens JWT (Qualquer texto longo e aleatório)
JWT_SECRET="um_segredo_super_seguro_e_aleatorio"

# Porta onde o servidor Express irá rodar (Normalmente injetado sozinho pela Hospedagem)
PORT=3000

# Configurações do Supabase para Storage (Upload de Arquivos)
SUPABASE_URL="https://sua-url-projeto.supabase.co"
SUPABASE_SERVICE_KEY="sua_chave_de_servico_secret_role"
